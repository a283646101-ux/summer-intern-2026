# ====================================
# 日常科普 - 环境变量配置
# ====================================
# 将此文件重命名为 .env.daily_science 并填入你的 API Key

# --- AI 模型 ---
# 方式一：智谱 GLM（推荐，有免费模型）
# API Key 获取：https://open.bigmodel.cn/
export ZHIPU_API_KEY=""

# 方式二：通义千问
# export DASHSCOPE_API_KEY="你的DashScope API Key"
# export SCIENCE_PROVIDER="qwen"

# --- QQ邮箱 SMTP（用于邮件推送）---
# 重要：这是授权码，不是QQ密码！
# 获取方式：QQ邮箱 → 设置 → 账户 → POP3/IMAP/SMTP服务 → 生成授权码
# 授权码是16位字母，长这样：xxxxxxxxxxxxxxxx
export SMTP_SENDER="2836461019@qq.com"
export SMTP_PASSWORD=""    # ← 把授权码填这里
export SMTP_RECIPIENT="2836461019@qq.com"
